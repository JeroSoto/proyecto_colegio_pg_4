# Example .env for proyecto_colegio
PORT=3000
HOST=0.0.0.0
JWT_SECRET=change_this_to_a_long_random_string
# DB_DIALECT can be 'sqlite' or 'mysql'. By default the app uses sqlite (no action needed).
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_NAME=colegio
# DB_USER=root
# DB_PASSWORD=your_mysql_password_here
# If using sqlite you can optionally set where to store the file:
# SQLITE_STORAGE=./data/database.sqlite
